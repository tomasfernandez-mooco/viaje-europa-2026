generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── TRIP ───────────────────────────────────────────────
model Trip {
  id         String   @id @default(uuid())
  name       String
  startDate  String
  endDate    String
  coverImage String?
  userId     String?
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  user           User?           @relation(fields: [userId], references: [id])
  members        TripMember[]
  reservations   Reservation[]
  itineraryItems ItineraryItem[]
  checklistItems ChecklistItem[]
  locations      Location[]
  expenses       Expense[]
  config         TripConfig[]
  travelers      Traveler[]

  @@map("trips")
}

// ─── USER ───────────────────────────────────────────────
model User {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String
  password        String
  avatar          String?
  role            String   @default("traveler")
  telegramChatId  String?  @unique
  createdAt       DateTime @default(now())

  trips           Trip[]
  tripMemberships TripMember[]

  @@map("users")
}

// ─── TRIP MEMBER ────────────────────────────────────────
model TripMember {
  id       String @id @default(uuid())
  tripId   String
  userId   String
  role     String @default("viewer") // "owner" | "editor" | "viewer"
  joinedAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@map("trip_members")
}

// ─── TRIP CONFIG (key-value per trip) ───────────────────
model TripConfig {
  id     String @id @default(uuid())
  tripId String
  key    String
  value  String

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, key])
  @@map("trip_config")
}

// ─── RESERVATION ────────────────────────────────────────
model Reservation {
  id                 String   @id @default(uuid())
  tripId             String
  type               String
  subtype            String?
  title              String
  city               String
  country            String
  provider           String?
  confirmationNumber String?
  reservationUrl     String?
  price              Float    @default(0)
  currency           String   @default("EUR")
  priceUSD           Float    @default(0)
  notes              String?
  attachmentUrl      String?
  status             String   @default("por-reservar")
  priority           String   @default("media")
  startDate          String
  endDate            String?
  freeCancellation   Boolean  @default(false)
  paid               Boolean  @default(false)
  deadlineDate       String?
  alert              String?
  travelers              Int      @default(2)
  travelerIds            String?
  linkedItineraryDates   String?
  createdAt              DateTime @default(now())

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@map("reservations")
}

// ─── ITINERARY ITEM ─────────────────────────────────────
model ItineraryItem {
  id            String   @id @default(uuid())
  tripId        String
  date          String
  time          String?
  title         String
  description   String?
  city          String
  country       String
  category      String
  status        String   @default("planned")
  alertLevel    String?
  reservationId String?
  orderIndex    Int      @default(0)
  createdAt     DateTime @default(now())

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@map("itinerary_items")
}

// ─── CHECKLIST ITEM ─────────────────────────────────────
model ChecklistItem {
  id        String   @id @default(uuid())
  tripId    String
  title     String
  completed Boolean  @default(false)
  category  String?
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// ─── LOCATION ───────────────────────────────────────────
model Location {
  id          String  @id @default(uuid())
  tripId      String
  city        String
  country     String
  lat         Float?
  lng         Float?
  image       String?
  description String?
  notes       String?
  orderIndex  Int     @default(0)
  dateRange   String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("locations")
}

// ─── EXPENSE ────────────────────────────────────────────
model Expense {
  id          String   @id @default(uuid())
  tripId      String
  category    String
  amount      Float
  currency    String   @default("EUR")
  amountUSD   Float    @default(0)
  description String?
  date        String
  receiptUrl        String?
  receiptDate       DateTime?
  paidByTravelerId  String?
  splitBetween      String?
  splitType         String    @default("equal")
  itineraryItemId   String?
  reservationId     String?
  createdAt         DateTime  @default(now())

  trip          Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  paidBy        Traveler?      @relation("ExpensePaidBy", fields: [paidByTravelerId], references: [id], onDelete: SetNull)
  itineraryItem ItineraryItem? @relation(fields: [itineraryItemId], references: [id], onDelete: SetNull)
  reservation   Reservation?   @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@map("expenses")
}

// ─── TRAVELER ───────────────────────────────────────────
model Traveler {
  id        String   @id @default(uuid())
  tripId    String
  name      String
  color     String   @default("#6366f1")
  userId    String?
  createdAt DateTime @default(now())

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expenses Expense[] @relation("ExpensePaidBy")

  @@map("travelers")
}

// ─── TELEGRAM SESSION ───────────────────────────────────
model TelegramSession {
  chatId    String   @id
  state     String   // "awaiting_email", "awaiting_type", "awaiting_confirm", etc.
  data      String?  // JSON-encoded session data
  updatedAt DateTime @updatedAt

  @@map("telegram_sessions")
}
